# There are 3 different types of shells in bash: the login shell, normal shell
# and interactive shell. Login shells read ~/.profile and interactive shells
# read ~/.bashrc; in our setup, /etc/profile sources ~/.bashrc - thus all
# settings made here will also take effect in a login shell.
#
# NOTE: It is recommended to make language settings in ~/.profile rather than
# here, since multilingual X sessions would not work properly if LANG is over-
# ridden in every subshell.

#VERSION: 20260710a

test -s ~/.alias && . ~/.alias || true

# If not running interactively, don't do anything
case $- in
    *i*) ;;
      *) return;;
esac

# .bashrc file from Chezmoi
echo "Chezmoi: START .bashrc"

export EDITOR=/usr/bin/nano
alias czm='chezmoi'
alias czmcd='cd ~/.local/share/chezmoi'

export XAUTHORITY="$HOME"/.Xauthority

export PS1="\n[\w]\n\u@\h $ "

#[ -s "${HOME}/.g/env" ] && \. "${HOME}/.g/env"
#unalias g

#export NVM_DIR="$HOME/.nvm"
#[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
#[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

#unset PATH
#PATH="$HOME/bin"

## Place Configurations below!
mkdir -p "$HOME"/.bashrc.d
chmod 700 "$HOME"/.bashrc.d
for file in $(compgen -G "$HOME/.bashrc.d/*.bashrc");
do
  chmod 700 "$file"
  echo "  Sourcing $file"
  source "$file"
done
## Place Configurations above!

alias czmcd='cd ~/.local/share/chezmoi'

echo "Chezmoi: END .bashrc"
